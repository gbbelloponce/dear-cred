model Installment {
  id              String            @id @default(cuid())
  loanId          String
  number          Int
  dueDate         DateTime
  amount          Float
  status          InstallmentStatus @default(PENDING)
  isPenalty       Boolean           @default(false)
  penaltySourceId String?
  createdAt       DateTime          @default(now())

  loan            Loan              @relation(fields: [loanId], references: [id])
  payments        Payment[]
  penaltySource   Installment?      @relation("PenaltySource", fields: [penaltySourceId], references: [id])
  penalties       Installment[]     @relation("PenaltySource")

  @@map("installments")
}
